{
  "position": "bottom",
  "height": 38,
  "modules-left": [
    "sway/workspaces",
    "custom/spotify"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "idle_inhibitor",
    "backlight",
    "pulseaudio",
    "temperature",
    "network",
    "custom/vpn",
    "battery",
    "bluetooth"
  ],
  "margin-top": 0,
  "margin-left": 15,
  "margin-right": 15,
  "margin-bottom": 10,
  "sway/workspaces": {
    "disable-scroll": false,
    "all-outputs": false,
    "format": "{icon}",
    "format-icons": {
      "1": "I",
      "2": "II",
      "3": "III",
      "4": "IV",
      "5": "V",
      "6": "VI",
      "7": "VII",
      "8": "VIII",
      "9": "IX",
      "10": "X"
    }
  },
  "clock": {
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "{:%H:%M %Z}  ",
    "format-alt": "{:%H:%M %a %d/%m/%y} ≤░Δ░ ",
    "timezones": [
      "Europe/London",
      "America/Los_Angeles"
    ],
    "actions": {
      "on-click-right": "tz_down"
    }
  },
  "idle_inhibitor": {
    "format": "{icon} ",
    "format-icons": {
      "activated": "≤░Ζ╢",
      "deactivated": "≤░╛ς"
    },
    "tooltip-format-activated": "Idle inhibitor: on",
    "tooltip-format-deactivated": "Idle inhibitor: off"
  },
  "backlight": {
    "format": " {icon} {percent}% ",
    "format-icons": [
      "ΌΟΞ", 
      "ΌΠΥ", 
      "ΌΠΣ", 
      "ΌΠΠ", 
      "ΌΠΟ", 
      "ΌΠΞ", 
      "ΌΠΛ", 
      "ΌΠΙ", 
      "ΌΟδ"
    ],
    "on-scroll-up": "light -A 1",
    "on-scroll-down": "light -U 1"
  },
  "battery": {
    "bat": "BAT0",
    "states": {
      "warning": 25,
      "critical": 5
    },
    "format": " {icon}  {capacity}% ",
    "tooltip-format": " {timeTo}, {capacity}% ",
    "format-plugged": " ≤░ΓΕ {capacity}% ",
    "format-charging": " ≤░λε {capacity}% ",
    "format-icons": [
      "≤░ΓΟ",
      "≤░Β╗",
      "≤░Β╛",
      "≤░ΓΑ",
      "≤░Β╣"
    ],
    "interval": 5
  },
  "pulseaudio": {
    "format": " {icon} {volume}% ",
    "format-muted": "≤░ΨΒ",
    "format-icons": [
      "≤░Χ┐",
      "≤░ΨΑ",
      "≤░Χ╛"
    ],
    "scroll-step": 1
  },
  "custom/vpn": {
    "exec": "nmcli con show --active 2>/dev/null | grep -oP '(FB-VPN|proton[^ ]*)' | head -1 | xargs -I{} echo ' {} ' || echo ''",
    "interval": 5
  },
  "network": {
    "format-wifi": " ≤░Ψσ {essid} ({signalStrength}%) ",
    "max-length": 20,
    "format-ethernet": " ≤░ΙΑ {ifname} ",
    "format-disconnected": " ≤░Ψς ",
    "tooltip-format": "{essid} {signalStrength}%",
    "on-click": "/usr/bin/nm-connection-editor"
  },
  "custom/spotify": {
    "exec": "python $HOME/.config/waybar/scripts/mediaplayer.py --player spotify",
    "exec-if": "pgrep spotify",
    "format": " {}",
    "escape": true,
    "max-length": 45,
    "return-type": "json",
    "on-click": "playerctl -p spotify play-pause",
    "on-scroll-up": "playerctl -p spotify next",
    "on-scroll-down": "playerctl -p spotify previous"
  },
  "temperature": {
    "thermal-zone": 1,
    "critical-threshold": 80,
    "format": " ≤░ΦΠ {temperatureC}┬░C ",
    "format-critical": " ≤░ΦΠ {temperatureC}┬░C ",
    "interval": 5,
    "on-click": "alacritty -e btop"
  },
  "bluetooth": {
    "format-off": " ≤░Γ▓ off ",
    "format-on": " ≤░Γψ disconnected ",
    "format-connected": " ≤░Γ▒ {device_alias} ",
    "format-connected-battery": " ≤░Γ▒ {device_alias}({device_battery_percentage}%) ",
    "interval": 5,
    "tooltip-format": "{status}",
    "on-click": "/usr/bin/blueman-manager"
  }
}
