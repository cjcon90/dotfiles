{
  "position": "bottom",
  "modules-left": ["sway/workspaces", "custom/spotify"],
  "modules-center": ["clock"],
  "modules-right": ["backlight","pulseaudio","temperature","network","battery","bluetooth"],
  "margin-top": 0,
  "margin-left": 15,
  "margin-right": 15,
  "margin-bottom": 10,

  // Modules configuration
 "sway/workspaces": {
     "disable-scroll": false,
     "all-outputs": false,
     "format": "{icon}",
     "format-icons": {
         "1": "I",
         "2": "II",
         "3": "III",
         "4": "IV",
         "5": "V",
         "6": "VI",
         "7": "VII",
         "8": "VIII",
         "9": "IX",
         "10": "X",
     }
   },
  "clock": {
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "{:%H:%M %Z} пЂ— ",
    "format-alt": "{:%H:%M %a %d/%m/%y} у°ѓ° ",
    "timezones": ["Europe/Dublin","America/Los_Angeles"],
    "actions": {
      "on-click-right": "tz_down",
    },
  },
  "backlight": {
    "format": " {icon} {}% ",
    "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"],
    "on-scroll-up": "light -A 1",
    "on-scroll-down": "light -U 1"
  },
  "battery": {
    "states": {
        "warning": 25,
        "critical": 5
    },
    "format": " {icon} {capacity}% ",
    "tooltip-format": " {timeTo}, {capacity}% ",
    "format-charging": " у°‚„ {capacity}% ",
    "format-charging": " п‡¦ {capacity}% ",
    "format-icons": ["у°‚Ћ", "у°Ѓ»", "у°Ѓѕ", "у°‚Ђ", "у°Ѓ№"]
  },
  "pulseaudio": {
    "format": " {icon} {volume}% ",
    "format-muted": "у°–Ѓ",
    "format-icons": ["у°–Ђ","у°•ѕ","пЂЁ"],
    "scroll-step": 1
  },
  "network": {
    "format-wifi": " у°–© {essid} ({signalStrength}%) ",
    "max-length": 20,
    "format-ethernet": " у°€Ђ {ifname} ",
    "format-disconnected": " у°–Є ",
    "on-click": "/usr/bin/nm-connection-editor"
  },
  "custom/spotify": {
      "exec": "python $HOME/.config/waybar/scripts/mediaplayer.py --player spotify",
      "format": "п†ј {}",
      "escape": true,
      "max-length": 45,
      "return-type": "json",
      "on-click": "playerctl -p spotify play-pause"
  },
  "temperature": {
    "thermal-zone": 1,
    "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
    "critical-threshold": 80,
    "format": " п‹‰ {temperatureC}В°C ",
    "format-critical": " п‹‡ {temperatureC}В°C ",
    "interval": 2
  },
  "bluetooth": {
    "format-off": " пЉ” off ",
    "format-on": " пЉ” disconnected ",
    "format-connected": " пЉ” {device_alias} ",
    "format-connected-battery": " пЉ” {device_alias}({device_battery_percentage}%) ", // need to set experimental: true in /etc/bluetooth/main.conf
    "interval": 5,
    "tooltip-format": "{status}",
    "on-click": "/usr/bin/blueman-manager"
  },
}



