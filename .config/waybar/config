{
  "position": "bottom",
  "modules-left": ["sway/workspaces", "custom/spotify"],
  "modules-center": ["clock"],
  "modules-right": ["backlight","pulseaudio","temperature","network","custom/protonvpn","battery","bluetooth"],
  "margin-top": 0,
  "margin-left": 15,
  "margin-right": 15,
  "margin-bottom": 10,

  // Modules configuration
 "sway/workspaces": {
     "disable-scroll": false,
     "all-outputs": false,
     "format": "{icon}",
     "format-icons": {
         "1": "I",
         "2": "II",
         "3": "III",
         "4": "IV",
         "5": "V",
         "6": "VI",
         "7": "VII",
         "8": "VIII",
         "9": "IX",
         "10": "X",
     }
   },
  "clock": {
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "{:%H:%M %Z} ΎΑΩ ",
    "format-alt": "{:%H:%M %a %d/%m/%y} ≤░Δ░ ",
    "timezones": ["Europe/London","America/Los_Angeles"],
    "actions": {
      "on-click-right": "tz_down",
    },
  },
  "backlight": {
    "format": " {icon} {0}% ",
    "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
    "on-scroll-up": "light -A 1",
    "on-scroll-down": "light -U 1"
  },
  "battery": {
    "bat": "BAT0",
    "states": {
        "warning": 25,
        "critical": 5
    },
    "format": " {icon}  {capacity}% ",
    "tooltip-format": " {timeTo}, {capacity}% ",
    "format-plugged": " ≤░ΓΕ {capacity}% ",
    "format-charging": " ΎΘο {capacity}% ",
    "format-icons": ["≤░ΓΟ", "≤░Β╗", "≤░Β╛", "≤░ΓΑ", "≤░Β╣"],
    "interval": 5
  },
  "pulseaudio": {
    "format": " {icon} {volume}% ",
    "format-muted": "≤░ΨΒ",
    "format-icons": ["≤░ΨΑ","≤░Χ╛","ΎΑρ"],
    "scroll-step": 1
  },
  "custom/protonvpn": {
    "exec": "nmcli con show --active | grep -q 'FB-VPN' && echo ' FB-VPN ' || ifconfig | grep -qE 'tun[0-9]' && echo ' VPN ' || echo ''",
    "interval": 5,
  },
  "network": {
    "format-wifi": " ≤░Ψσ {essid} ({signalStrength}%) ",
    "max-length": 20,
    "format-ethernet": " ≤░ΙΑ {ifname} ",
    "format-disconnected": " ≤░Ψς ",
    "tooltip-format": "{essid} {signalStrength}%",
    "on-click": "/usr/bin/nm-connection-editor"
  },
  "custom/spotify": {
      "exec": "python $HOME/.config/waybar/scripts/mediaplayer.py --player spotify",
      "format": "ΎΗ╝ {}",
      "escape": true,
      "max-length": 45,
      "return-type": "json",
      "on-click": "playerctl -p spotify play-pause"
  },
  "temperature": {
    "thermal-zone": 1,
    "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
    "critical-threshold": 80,
    "format": " ΎΜΚ {temperatureC}┬░C ",
    "format-critical": " ΎΜΘ {temperatureC}┬░C ",
    "interval": 5
  },
  "bluetooth": {
    "format-off": " ΎΛΦ off ",
    "format-on": " ΎΛΦ disconnected ",
    "format-connected": " ΎΛΦ {device_alias} ",
    "format-connected-battery": " ΎΛΦ {device_alias}({device_battery_percentage}%) ", // need to set experimental: true in /etc/bluetooth/main.conf
    "interval": 5,
    "tooltip-format": "{status}",
    "on-click": "/usr/bin/blueman-manager"
  },
}



