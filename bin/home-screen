#!/bin/sh
SCREENS=$(xrandr |grep connected | grep -wv disconnected | wc -l)
echo $SCREENS
if [ $SCREENS -eq 2 ]; then
    xrandr --output eDP-1 --mode 3840x2400 --scale 0.5x0.5 --pos 3840x0 --rotate normal --output DP-1 --off --output HDMI-1 --primary --mode 1920x1080 --pos 0x0 --rotate normal --output DP-2 --off
else
    xrandr --output eDP-1 --primary --scale 0.5x0.5 --mode 3840x2400 --pos 0x0 --rotate normal --output DP-1 --off --output HDMI-1 --off --output DP-2 --off

fi
conky -c .conkyrc 2> /dev/null
sleep 2
/usr/bin/python3 /home/ciaranconcannon/bin/island_time.py
